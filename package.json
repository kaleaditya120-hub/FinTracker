{
  "name": "tab-finance-tracker-backend",
  "version": "1.0.0",
  "description": "Express + PostgreSQL API for the Tab. student finance tracker",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "db:setup": "psql -U $npm_config_user -d $npm_config_db -f db/schema.sql",
    "db:seed": "psql -U $npm_config_user -d $npm_config_db -f db/seed.sql"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "pg": "^8.12.0"
  },
  "devDependencies": {
    "nodemon": "^3.1.4"
  }
}
